<h1>映画詳細</h1>

<div>
<table>
  <tbody>
        <th>ID</th>
          <td><%= @movie.id %></td>
        <th>タイトル</th>
          <td><%= @movie.name %></td>
        <th>公開年</th>
          <td><%= @movie.year%></td>
        <th>概要</th>
          <td><%= @movie.description %></td>
        <th>画像URL</th>
          <td><%= link_to '画像', @movie.image_url, target: '_blank', rel: 'noopener noreferrer' %></td>
        <th>上映中</th>
          <td><%= @movie.showing? ? '上映中' : '上映予定' %></td>
        <th>登録日時</th>
          <td><%= @movie.created_at %></td>
        <th>更新日時</th>
          <td><%= @movie.updated_at %></td>
  </tbody>
</table>

</div>
