<% if notice %>
<p class="notice"><%= notice %></p>
<% end %>

<section class="admin-movies">
  <h2>映画一覧</h2>
  <%= link_to '新規追加', new_admin_movie_path, class: 'btn btn-primary' %>

  <table class="movie-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>タイトル</th>
        <th>公開年</th>
        <th>概要</th>
        <th>画像URL</th>
        <th>上映中</th>
        <th>上映スケジュール</th>
        <th>登録日時</th>
        <th>更新日時</th>
      </tr>
    </thead>
    <tbody>
      <% @movies.each do |movie| %>
        <tr>
          <td><%= link_to movie.id, edit_admin_movie_path(movie) %></td>
          <td><%= movie.name %></td>
          <td><%= movie.year%></td>
          <td><%= movie.description %></td>
          <td><% if movie.image_url.present? %><img src="<%= movie.image_url %>"><% end %></td>
          <td><%= movie.showing? ? '上映中' : '上映予定' %></td>
          <td>
            <% movie.schedules.each do |schedule| %>
              <div><%= schedule.start_time %> 〜 <%= schedule.end_time %></div>
            <% end %>
          </td>
          <td><%= movie.created_at %></td>
          <td><%= movie.updated_at %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
